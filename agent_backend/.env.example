# FitForge Coach Agent backend environment example.
# Copy this file to `.env` for local backend development.
#
# Never commit real API keys. Real LLM provider keys belong only in the
# backend environment; the Flutter client must not store, bundle, or forward
# provider API keys.
#
# Public deployments must set FITFORGE_AGENT_AUTH_TOKEN and configure CORS for
# their own frontend origin. Do not commit real backend client tokens.
# These limits are basic exposure controls, not complete abuse protection.

LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=30

# Optional backend orchestration boundary. Defaults to native.
# native keeps the existing FitForge mock/real provider behavior.
# langgraph is experimental and must remain optional.
FITFORGE_AGENT_ORCHESTRATOR=native

# Optional backend-only privacy-safe tracing. Disabled by default.
FITFORGE_AGENT_TRACE=0

FITFORGE_AGENT_AUTH_TOKEN=
FITFORGE_MAX_REQUEST_BYTES=65536
FITFORGE_MAX_CONTEXT_CHARS=12000
FITFORGE_RATE_LIMIT_PER_MINUTE=60
FITFORGE_CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173
